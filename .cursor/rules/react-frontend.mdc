## Text & Translation

Mọi text hiển thị cho user **bắt buộc** qua i18n. Thêm text mới thì phải thêm key dịch (translation).

```typescript
// ❌ BAD
<button>Submit</button>
<span>Welcome to TimmyHub</span>

// ✅ GOOD
const { t } = useTranslation();
<button>{t('common.submit')}</button>
<span>{t('welcome.title')}</span>
```

## Constants & Enums

- Magic number/string đặt trong file constant (ví dụ: `constants/validation.ts`, `constants/routes.ts`).
- Tập giá trị cố định (status, type, role...) dùng enum hoặc const object as const.

```typescript
// constants/validation.ts
export const PASSWORD_MIN_LENGTH = 8;
export const MAX_FILE_SIZE_MB = 5;

// constants/status.ts hoặc dùng enum
export enum OrderStatus {
  PENDING = 'PENDING',
  CONFIRMED = 'CONFIRMED',
  SHIPPED = 'SHIPPED',
}
```

## Component Checklist

Every component must have:
- [ ] TypeScript interface for props (TUYỆT ĐỐI không `any`)
- [ ] Component size < 200 dòng (nếu lớn → tách nhỏ)
- [ ] Xác định Server Component hay Client Component ('use client' chỉ khi cần)
- [ ] Data fetching strategy (SSR vs CSR) hợp lý
- [ ] Loading state (Skeleton)
- [ ] Error state (và Error Boundary nếu cần)
- [ ] Empty state
- [ ] Responsive (Mobile first)
- [ ] Mọi text qua i18n (có translation)
- [ ] Accessibility (ARIA)
- [ ] React Query cho CSR (với query key specific, staleTime hợp lý)
- [ ] Mantine + Tailwind (không inline style, không Styled Components)
- [ ] Query optimization (parallel fetch, selective fields, prefetch)
- [ ] Form: Mantine Form + Zod validation (nếu là form)
- [ ] Image: Next.js Image component (không dùng <img>)
- [ ] SEO: Metadata cho page (static hoặc generateMetadata)
- [ ] Route protection: Check auth/authorization nếu là protected route

## Form Handling

Dùng Mantine Form + Zod validation. Mọi form phải có validation và error handling.

```typescript
// ✅ GOOD - Mantine Form + Zod
import { useForm } from '@mantine/form';
import { zodResolver } from 'mantine-form-zod-resolver';
import { z } from 'zod';
import { TextInput, Button } from '@mantine/core';
import { useTranslation } from 'react-i18next';

const schema = z.object({
  email: z.string().email('validation.email.invalid'),
  password: z.string().min(8, 'validation.password.min'),
});

export function LoginForm() {
  const { t } = useTranslation();
  const form = useForm({
    initialValues: { email: '', password: '' },
    validate: zodResolver(schema),
    transformValues: (values) => schema.parse(values),
  });

  return (
    <form onSubmit={form.onSubmit(handleSubmit)}>
      <TextInput
        label={t('form.email')}
        {...form.getInputProps('email')}
        error={form.errors.email && t(form.errors.email)}
      />
      <Button type="submit">{t('common.submit')}</Button>
    </form>
  );
}

// ❌ BAD - Không có validation
function LoginForm() {
  const [email, setEmail] = useState('');
  return <input value={email} onChange={(e) => setEmail(e.target.value)} />;
}
```

## Error Boundaries

Dùng Error Boundary cho error handling toàn cục. Mỗi route/page nên có error boundary.

```typescript
// ✅ GOOD - Error Boundary
'use client';

import { Component, ReactNode } from 'react';
import { Button } from '@mantine/core';
import { useTranslation } from 'react-i18next';

interface Props {
  children: ReactNode;
  fallback?: ReactNode;
}

interface State {
  hasError: boolean;
}

export class ErrorBoundary extends Component<Props, State> {
  constructor(props: Props) {
    super(props);
    this.state = { hasError: false };
  }

  static getDerivedStateFromError(): State {
    return { hasError: true };
  }

  render() {
    if (this.state.hasError) {
      return this.props.fallback || <ErrorFallback />;
    }
    return this.props.children;
  }
}

function ErrorFallback() {
  const { t } = useTranslation();
  return (
    <div className="flex flex-col items-center justify-center min-h-screen">
      <h1>{t('error.somethingWentWrong')}</h1>
      <Button onClick={() => window.location.reload()}>
        {t('common.reload')}
      </Button>
    </div>
  );
}
```

## AG Grid Patterns

Mọi AG Grid table phải có: typed column defs, server-side operations, custom renderers.

```typescript
// ✅ GOOD - AG Grid với types và server-side
import { AgGridReact } from 'ag-grid-react';
import { ColDef } from 'ag-grid-community';
import { useQuery } from '@tanstack/react-query';

interface Product {
  id: string;
  name: string;
  price: number;
  stock: number;
}

const columnDefs: ColDef<Product>[] = [
  { field: 'name', headerName: 'Tên sản phẩm', sortable: true, filter: true },
  { 
    field: 'price', 
    headerName: 'Giá',
    cellRenderer: (params: { value: number }) => {
      return `${params.value.toLocaleString('vi-VN')} đ`;
    },
  },
  { field: 'stock', headerName: 'Tồn kho', type: 'numberColumn' },
];

export function ProductTable() {
  const { data, isLoading } = useQuery({
    queryKey: ['products'],
    queryFn: () => productService.getAll(),
  });

  return (
    <div className="ag-theme-alpine h-[600px]">
      <AgGridReact
        rowData={data}
        columnDefs={columnDefs}
        pagination={true}
        paginationPageSize={20}
        loading={isLoading}
        rowSelection="multiple"
        onGridReady={(params) => {
          params.api.sizeColumnsToFit();
        }}
      />
    </div>
  );
}
```

## Route Protection

Protected routes phải check authentication/authorization. Dùng middleware hoặc HOC.

```typescript
// ✅ GOOD - Route protection với middleware
// middleware.ts
import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

export function middleware(request: NextRequest) {
  const token = request.cookies.get('auth-token');
  
  if (!token && request.nextUrl.pathname.startsWith('/admin')) {
    return NextResponse.redirect(new URL('/login', request.url));
  }
  
  return NextResponse.next();
}

export const config = {
  matcher: ['/admin/:path*', '/dashboard/:path*'],
};

// ✅ GOOD - Component-level protection
'use client';
import { useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { useAuth } from '@/hooks/useAuth';

export function ProtectedRoute({ children }: { children: React.ReactNode }) {
  const { user, isLoading } = useAuth();
  const router = useRouter();

  useEffect(() => {
    if (!isLoading && !user) {
      router.push('/login');
    }
  }, [user, isLoading, router]);

  if (isLoading) return <LoadingSkeleton />;
  if (!user) return null;
  
  return <>{children}</>;
}
```

